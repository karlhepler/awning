# ==============================================================================
# Bond Bridge Configuration
# ==============================================================================

# Get BOND_TOKEN from Bond Home app → Settings → Advanced Settings
BOND_TOKEN=your_bond_token_here

# ==============================================================================
# IMPORTANT: Bond Bridge IP Address
# ==============================================================================
# Your Bond Bridge requires a stable IP address. We STRONGLY recommend setting
# up a DHCP reservation in your router. This is best practice for ALL IoT
# devices - it ensures the IP never changes even after router reboots.
#
# How to set up a DHCP reservation:
# 1. Find your Bond Bridge's MAC address in Bond Home app → Settings
# 2. Log into your router's admin panel (usually 192.168.1.1 or 192.168.0.1)
# 3. Look for "DHCP Reservation", "Static DHCP", or "Address Reservation"
# 4. Create a reservation binding the Bond's MAC address to a fixed IP
#
# To find your Bond Bridge's current IP:
# - Check your router's connected devices list, or
# - Use the Bond Home app → Settings → Device Info
# ==============================================================================
BOND_HOST=192.168.1.XXX

# Device ID for your awning
# Find in Bond Home app → Select Device → Settings → Advanced
DEVICE_ID=your_device_id_here

# ==============================================================================
# Weather Automation Configuration
# ==============================================================================
# The automation opens the awning ONLY if ALL 7 conditions are met:
#   1. ✓ Sunny (three-layer gate — see below)
#   2. ✓ Calm (wind speed below threshold)
#   3. ✓ No rain (precipitation = 0 mm/h)
#   4. ✓ Above 60°F (temperature > MIN_TEMPERATURE_F)
#   5. ✓ Daytime (current time between sunrise and sunset)
#   6. ✓ Sun high enough (altitude above threshold, accounts for trees)
#   7. ✓ Sun facing SE (sun azimuth 90°-260° for southeast-facing window)
#
# Sunshine detection uses a three-layer gate:
#
#   Layer 1 — model forecast ('do we want shade?'):
#     sunny_model = (shortwave_radiation >= MIN_GHI_WM2) OR (uv_index >= MIN_UV_INDEX)
#     GHI comes from ECMWF; UV Index from GFS — cross-model corroboration.
#     Either signal alone is sufficient — awning blocks UV AND heat/brightness.
#
#   Layer 2 — multi-variable consistency check (independent model variable cross-check):
#     sunny_observed = (direct_normal_irradiance >= MIN_DNI_WM2) OR (cloud_cover < MAX_CLOUD_COVER_PCT)
#     DNI and cloud_cover come from different NWP model schemes:
#       DNI/GHI: derived from the model's radiative transfer scheme
#       cloud_cover: derived from the model's humidity field (Sundqvist 1989)
#     When they disagree, one is wrong. OR allows either to confirm sunny,
#     preventing false-closes when DNI is intermittent on partly-cloudy days.
#
#   Layer 3 — hard cloud-cover ceiling (overcast override):
#     not_overcast = cloud_cover_mid < OVERCAST_THRESHOLD_PCT
#     When cloud_cover_mid (altostratus/altocumulus) is very high (>= OVERCAST_THRESHOLD_PCT),
#     mid-level clouds block direct sun regardless of what DNI reports. Total cloud
#     cover is NOT used here because high cirrus saturates it to 100% even when the
#     sun is visibly shining. Mid-level clouds are the reliable optical discriminator.
#
#   sunny_enough = sunny_model AND sunny_observed AND not_overcast
#
# If ANY condition fails, the awning will close.
# ==============================================================================

# Location - Used for weather data AND sun position calculation
# Find your coordinates at https://www.latlong.net/ or Google Maps (right-click → coordinates)
LATITUDE=37.7749
LONGITUDE=-122.4194

# Minimum global horizontal irradiance (W/m²) - first "sunny" signal
# GHI measures total solar energy reaching a horizontal surface (direct + diffuse).
# The awning opens if GHI is AT OR ABOVE this threshold (OR if UV qualifies below).
# GHI comes from ECMWF's shortwave_radiation field.
# Typical values:
#   0-150 W/m²: Heavy overcast — genuinely dark, no shade needed
#   150-350 W/m²: Moderate overcast or haze
#   350-500 W/m²: Partly cloudy or thin clouds — shade starts to matter
#   500-900 W/m²: Clear sky midday
# Default 400 W/m² is the "enough sun to matter" threshold — opens for partly
# cloudy to clear conditions, closes for genuinely overcast skies.
MIN_GHI_WM2=400

# Minimum UV Index - second "sunny" signal (from a separate NWP model, GFS)
# UV Index measures ultraviolet radiation intensity on a standard scale.
# The awning opens if UV Index is AT OR ABOVE this threshold (OR if GHI qualifies above).
# UV Index scale:
#   0-2: Low — no protection needed
#   3-5: Moderate — some protection recommended
#   6-7: High — protection recommended
#   8+:  Very High / Extreme
# Default 4 is the "you'd recommend sunscreen" threshold. Captures cloudy days
# where UV passes through cloud gaps even when GHI is suppressed.
MIN_UV_INDEX=4

# Minimum direct normal irradiance (W/m²) - Layer 2 consistency check
# DNI comes from the NWP model's radiative transfer scheme (not observational).
# The awning opens only if DNI meets this threshold OR cloud cover is below MAX_CLOUD_COVER_PCT.
# Rainy/overcast values: 4-14 W/m². Typical partly-cloudy: 100-500 W/m².
# Default 50 W/m² is well above overcast noise but permits partly-cloudy opens.
MIN_DNI_WM2=50

# Maximum total cloud cover (%) - Layer 2 consistency check
# cloud_cover comes from the NWP model's humidity-based scheme (Sundqvist 1989),
# a structurally independent scheme from the radiative-transfer-derived DNI/GHI.
# The awning opens only if cloud cover is below this threshold OR DNI >= MIN_DNI_WM2.
# Default 80% blocks most overcast days while allowing partly-cloudy opens (40-70%).
MAX_CLOUD_COVER_PCT=80

# Mid-level cloud cover hard ceiling (%) - Layer 3 overcast override
# When cloud_cover_mid (altostratus/altocumulus) reaches this level, DNI is
# overridden and the awning stays closed. Mid-level clouds are the optical layer
# that determines whether direct sun reaches the ground.
# NOTE: Total cloud cover is NOT used here because it saturates to 100% when high
# cirrus is present, even when the sun is visibly shining. Cirrus (high clouds) are
# thin and do not block awning-relevant sun. Low clouds (fog/stratus) are handled
# by the DNI gate. Only mid-level clouds (altostratus/altocumulus) reliably
# indicate that direct sun is blocked.
# Set above MAX_CLOUD_COVER_PCT (80%) so it only fires for true overcast (95-100%),
# not for the partly-cloudy range where DNI rescue is appropriate.
# Default 95%.
OVERCAST_THRESHOLD_PCT=95

# Minimum temperature (°F) - 'warm enough to want shade' threshold
# The awning opens only if the temperature is above this value.
# Default 60°F — warm enough that shade is actually desirable.
# (Prior behavior used 40°F as a safety-above-freezing check, not a comfort check.)
MIN_TEMPERATURE_F=60

# Minimum sun altitude (degrees above horizon) - Controls "Sun high enough" condition
# Accounts for trees or obstacles that may block low sun
# 0° = on horizon, 90° = directly overhead
# Typical value: 10-20° depending on your landscape
MIN_SUN_ALTITUDE_DEG=10

# Wind speed threshold (mph) - Controls "Calm" condition
# Awning opens if wind speed is BELOW this speed
# IMPORTANT: Set conservatively below your awning's built-in wind sensor (typically 30 mph)
# Typical values: 8-12 mph (10 mph is a safe default for most residential awnings)
WIND_SPEED_THRESHOLD_MPH=10

# Hardcoded conditions (cannot be configured):
# - Rain: Any precipitation closes awning (0 mm/h threshold)
# - Daytime: Automatically determined from sunrise/sunset
# - Sun position: Azimuth 90°-260° (for southeast-facing window)

# ==============================================================================
# Cron Job Setup Example
# ==============================================================================
# First, create a logs directory: mkdir -p ~/logs
#
# Then add to your crontab (crontab -e):
#
# Option 1: Specify .env file path explicitly (RECOMMENDED for cron)
# */15 * * * * nix run /Users/YOUR_USERNAME/path/to/awning#automation -- --env-file=/Users/YOUR_USERNAME/path/to/awning/.env >> ~/logs/awning-automation.log 2>&1
#
# Option 2: Change to project directory (auto-finds .env in current directory)
# */15 * * * * cd /Users/YOUR_USERNAME/path/to/awning && nix run .#automation >> ~/logs/awning-automation.log 2>&1
#
# The automation will only open the awning when ALL conditions are met.
# It checks the current awning state before taking action, so it won't
# repeatedly send open/close commands if the awning is already in the desired state.

# ==============================================================================
# Telegram Notifications (optional)
# ==============================================================================
# Get notifications when awning opens/closes or on errors
# Get bot token from @BotFather on Telegram
# Get chat ID by messaging @userinfobot (or use a group/channel ID)
# TELEGRAM_BOT_TOKEN=your_bot_token_here
# TELEGRAM_CHAT_ID=your_chat_id_here

# ==============================================================================
# Bond Bridge ID (optional, for mDNS discovery)
# ==============================================================================
# Used by deploy.sh to automatically discover Bond Bridge IP via mDNS
# Find in Bond Home app → Settings → Device Info (e.g., ZZIF27980)
# BOND_ID=your_bond_id_here

# ==============================================================================
# Logging Configuration (optional)
# ==============================================================================
# Logs are stored in ~/.config/awning/logs/ with daily rotation
# A symlink at ~/awning.log always points to today's log file

# Number of days to keep log files before automatic cleanup
# Default: 30 days
# LOG_RETENTION_DAYS=30
